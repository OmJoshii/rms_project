{
  "name": "rms-print-agent",
  "version": "2.1.1",
  "description": "Local Node.js relay that receives kitchen tickets on localhost and prints them to the Epson TM-T20IV over raw TCP 9100.",
  "main": "src/electron-main.js",
  "scripts": {
    "test": "node --test",
    "start": "node src/index.js",
    "desktop": "electron .",
    "pack": "electron-builder --dir --universal",
    "dist": "electron-builder --publish never --universal",
    "pack:win": "electron-builder --dir --win --x64",
    "dist:win": "electron-builder --publish never --win --x64"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.timur.rmsprintrelay",
    "productName": "RMS Print Relay",
    "asar": true,
    "files": [
      "src/**/*",
      "config.example.json",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "license": "UNLICENSED",
  "private": true
}
