<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rms_sale_order_form_view" model="ir.ui.view">
        <field name="name">sale.order.form.rms.delivery</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='note']" position="before">
                <group string="Online Order Fulfillment" col="2"
                       invisible="rms_delivery_type == False">
                    <field name="rms_delivery_type" readonly="1"/>
                    <field name="rms_delivery_address" readonly="1"
                           invisible="rms_delivery_type != 'delivery'"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
